@page "/Station/Create"
@using DublinBikes.BlazorClient.Models
@using System.Net.Http.Json
@layout MainLayout
@inject HttpClient http
@inject NavigationManager Nav

<div class="row">
    <div class="col-lg-8">
        <h1 class="mb-5">New Station</h1>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Number</label>
            <div class="col-md-8">
                <input type="number" class="form-control" @bind="_station.Number" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Station Name</label>
            <div class="col-md-8">
                <input class="form-control" @bind="_station.Name" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Address</label>
            <div class="col-md-8">
                <input class="form-control" @bind="_station.Address" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Bike Stands</label>
            <div class="col-md-8">
                <input type="number" class="form-control" @bind="_station.BikeStands" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Available Bikes</label>
            <div class="col-md-8">
                <input type="number" class="form-control" @bind="_station.AvailableBikes" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Available Stands</label>
            <div class="col-md-8">
                <input type="number" class="form-control" @bind="_station.AvailableBikeStands" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Status</label>
            <div class="col-md-8">
                <select class="form-select" @bind="_station.Status">
                    <option value="OPEN">OPEN</option>
                    <option value="CLOSED">CLOSED</option>
                </select>
            </div>
        </div>

        @if (_error != null)
        {
            <div class="alert alert-danger">@_error</div>
        }

        <div class="row">
            <div class="offset-md-4 col-md-4 d-grid">
                <button class="btn btn-primary" @onclick="SaveStation">Create</button>
            </div>
            <div class="col-md-4 d-grid">
                <a class="btn btn-outline-primary" href="/station">Cancel</a>
            </div>
        </div>
    </div>
</div>

@code {
    private Station _station = new() { Status = "OPEN" };
    private string? _error;

    private async Task SaveStation()
    {
        try
        {
            var response = await http.PostAsJsonAsync(
                "https://localhost:7259/api/V1/stations", _station);

            if (response.IsSuccessStatusCode)
                Nav.NavigateTo("/station");
            else
                _error = $"Error: {response.StatusCode}";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}