@page "/Station/Create"
@using Microsoft.AspNetCore.Components
@inject StationsApiClient Api
@inject NavigationManager Nav
@using DublinBikes.BlazorClient.Models

<div class="row">
    <div class="col-lg-8">
        <h1 class="mb-5">~New Station</h1>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Number</label>
            <div class="col-md-8">
                <input type="number" class="form-control" @bind="StationDto.number">
                <span class="text-danger">@Errors["number"]?[0]</span>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Contract Name</label>
            <div class="col-md-8">
                <input class="form-control" @bind="StationDto.contract_name">
                <span class="text-danger">@Errors["contract_name"]?[0]</span>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Station Name</label>
            <div class="col-md-8">
                <input class="form-control" @bind="StationDto.name">
                <span class="text-danger">@Errors["name"]?[0]</span>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Address</label>
            <div class="col-md-8">
                <input class="form-control" @bind="StationDto.address">
                <span class="text-danger">@Errors["address"]?[0]</span>
            </div>
        </div>


        <!-- BIKE INFO -->
        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Bike Stands</label>
            <div class="col-md-8">
                <input type="number" class="form-control" @bind="StationDto.bike_stands">
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Available Bike Stands</label>
            <div class="col-md-8">
                <input type="number" class="form-control" @bind="StationDto.available_bike_stands">
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Available Bikes</label>
            <div class="col-md-8">
                <input type="number" class="form-control" @bind="StationDto.available_bikes">
            </div>
        </div>

        <!-- STATUS -->
        <div class="row mb-3">
            <label class="col-md-4 col-form-label">Status</label>
            <div class="col-md-8">
                <select class="form-select" @bind="StationDto.status">
                    <option value="OPEN">OPEN</option>
                    <option value="CLOSED">CLOSED</option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="offset-md-4 col-md-4 d-grid">
                <button class="btn btn-primary" @onclick="SaveStation">Submit</button>
            </div>
            <div class="col-md-4 d-grid">
                <a class="btn btn-outline-primary" href="/station">Cancel</a>
            </div>
        </div>
    </div>
</div>

@using System.Net.Http.Json
@using System.Text.Json.Nodes
@inject NavigationManager Nav
@inject HttpClient http


@code {
    public StationDto StationDto { get; set; } = new();
    public JsonNode Errors { get; set; } = new JsonObject();

    protected async Task SaveStation()
    {
        var response = await http.PostAsJsonAsync("https://localhost:7259/api/V2/stations", StationDto);
        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/station");
        }
        else 
        {
            var strResponse = await response.Content.ReadAsStringAsync();
            Console.WriteLine("Json Respomse: \n" + strResponse);

            try
            {
                var jsonResponse = JsonNode.Parse(strResponse);
                Errors = jsonResponse?["errors"] ?? new JsonObject();

            }
            catch (Exception ex)
            {
                Console.WriteLine("Error parsing JSON response: " + ex.Message);
                Errors = new JsonObject
                {
                    ["general"] = new JsonArray("An unexpected error occurred.")
                };
            }
    }
    }





}